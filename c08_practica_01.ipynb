      "Porcentaje de mayores: 70 %\n",
      "Edad más alta entre los menores: 17\n",
      "Edad más baja entre los mayores: 19\n"
     ]
    },
    {
     "data": {
      "text/plain": [
       "\u001b[36medades\u001b[39m: \u001b[32mList\u001b[39m[\u001b[32mInt\u001b[39m] = \u001b[33mList\u001b[39m(\u001b[32m17\u001b[39m, \u001b[32m34\u001b[39m, \u001b[32m22\u001b[39m, \u001b[32m15\u001b[39m, \u001b[32m45\u001b[39m, \u001b[32m19\u001b[39m, \u001b[32m28\u001b[39m, \u001b[32m16\u001b[39m, \u001b[32m31\u001b[39m, \u001b[32m42\u001b[39m)\n",
