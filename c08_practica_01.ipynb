    "println(\"\\nPuntuación por cuartos:\")\n",
    "cuartos.zipWithIndex.foreach { case ((local, visitante), index) =>\n",
    "    println(f\"  Q${index + 1}: $local - $visitante\")\n",
    "}"
   ]
