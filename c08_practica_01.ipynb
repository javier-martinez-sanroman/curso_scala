    "println(f\"Precios > 30€:       ${preciosSuperiores.map(p => f\"$p%.2f\").mkString(\"List(\", \", \", \")\")}\")\n",
    "println(f\"Ahorro total:        ${ahorroTotal}%.2f€\")"
   ]
  },
