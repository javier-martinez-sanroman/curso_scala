      "Ahorro total:        47.31€\n"
     ]
    },
    {
     "data": {
      "text/plain": [
       "\u001b[36mprecios\u001b[39m: \u001b[32mList\u001b[39m[\u001b[32mDouble\u001b[39m] = \u001b[33mList\u001b[39m(\u001b[32m12.99\u001b[39m, \u001b[32m45.0\u001b[39m, \u001b[32m8.5\u001b[39m, \u001b[32m120.0\u001b[39m, \u001b[32m33.75\u001b[39m, \u001b[32m5.2\u001b[39m, \u001b[32m89.99\u001b[39m)\n",
       "\u001b[36mconDescuento\u001b[39m: \u001b[32mList\u001b[39m[\u001b[32mDouble\u001b[39m] = \u001b[33mList\u001b[39m(\n",
       "  \u001b[32m11.0415\u001b[39m,\n",
       "  \u001b[32m38.25\u001b[39m,\n",
       "  \u001b[32m7.225\u001b[39m,\n",
       "  \u001b[32m102.0\u001b[39m,\n",
       "  \u001b[32m28.6875\u001b[39m,\n",
