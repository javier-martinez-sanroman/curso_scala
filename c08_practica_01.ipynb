       "  \u001b[32m\"spark\"\u001b[39m,\n",
       "  \u001b[32m\"usa\"\u001b[39m,\n",
       "  \u001b[32m\"scala\"\u001b[39m\n",
       ")\n",
       "\u001b[36mpalabrasMas3Letras\u001b[39m: \u001b[32mString\u001b[39m = \u001b[32m\"BIG | DATA | FUNCIONAL | LENGUAJE | OBJETOS | ORIENTADO | PARA | POTENTE | SCALA | SPARK | USA\"\u001b[39m"
      ]
     },
