    "val historial = Vector.empty[String] :+ \"usuario_01 login\" :+ \"usuario_02 login\" :+ \"usuario_01 logout\" :+ \"usuario_03 login\" :+ \"usuario_02 logout\" :+ \"usuario_03 logout\"\n",
    "\n",
    "println(s\"Historial (${historial.length} entradas):\")\n",
    "historial.zipWithIndex.foreach { case (evento, i) =>\n",
    "    println(f\"  ${i + 1}. $evento\")\n",
    "}\n",
    "\n",
    "val logins = historial.filter(_.contains(\"login\"))\n",
    "println(s\"\\nEventos login (${logins.length}):\")\n",
    "logins.foreach(println)\n",
    "\n",
    "val usuariosUnicos = historial.map(_.split(\" \")(0)).distinct\n",
