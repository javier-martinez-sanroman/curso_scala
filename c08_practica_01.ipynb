   "source": [
    "val texto = List(\n",
    "  \"scala\", \"es\", \"un\", \"lenguaje\", \"scala\", \"funcional\",\n",
    "  \"y\", \"orientado\", \"a\", \"objetos\", \"scala\", \"es\", \"potente\",\n",
    "  \"para\", \"big\", \"data\", \"y\", \"spark\", \"usa\", \"scala\"\n",
    ")\n",
    "\n",
    "val palabrasMas3Letras = texto\n",
    "    .filter(_.length >= 3)\n",
    "    .distinct\n",
    "    .sorted\n",
    "    .map(_.toUpperCase)\n",
    "    .mkString(\" | \")\n",
