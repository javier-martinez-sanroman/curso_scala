       "  \u001b[32m\"usuario_01 logout\"\u001b[39m,\n",
       "  \u001b[32m\"usuario_03 login\"\u001b[39m,\n",
       "  \u001b[32m\"usuario_02 logout\"\u001b[39m,\n",
       "  \u001b[32m\"usuario_03 logout\"\u001b[39m\n",
       ")\n",
       "\u001b[36mlogins\u001b[39m: \u001b[32mVector\u001b[39m[\u001b[32mString\u001b[39m] = \u001b[33mVector\u001b[39m(\n",
       "  \u001b[32m\"usuario_01 login\"\u001b[39m,\n",
       "  \u001b[32m\"usuario_02 login\"\u001b[39m,\n",
       "  \u001b[32m\"usuario_03 login\"\u001b[39m\n",
