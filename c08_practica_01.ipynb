       "  \u001b[32m\"es\"\u001b[39m,\n",
       "  \u001b[32m\"potente\"\u001b[39m,\n",
       "  \u001b[32m\"para\"\u001b[39m,\n",
       "  \u001b[32m\"big\"\u001b[39m,\n",
       "  \u001b[32m\"data\"\u001b[39m,\n",
