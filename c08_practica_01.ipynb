    "val localArray      = Array(21, 18, 25, 19)\n",
    "val visitanteArray  = Array(17, 22, 20, 24)\n",
    "\n",
    "val localPuntuacion = localArray.sum\n",
    "val visitantePuntuacion = visitanteArray.sum\n",
    "\n",
    "println(s\"Puntuación Local: ${localPuntuacion}\")\n",
