   "source": [
    "val precios = List(12.99, 45.00, 8.50, 120.00, 33.75, 5.20, 89.99)\n",
    "\n",
    "val conDescuento = precios.map(p => p * 0.85)\n",
    "val preciosSuperiores = precios.filter(_ > 30.0)\n",
    "val ahorroTotal = precios.sum - conDescuento.sum\n",
    "\n",
    "println(f\"Precios:             ${precios.mkString(\"List(\", \", \", \")\")}\")\n",
