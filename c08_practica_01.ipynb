    "val localArray      = Array(21, 18, 25, 19)\n",
    "val visitanteArray  = Array(17, 22, 20, 24)\n",
    "\n",
    "val localPuntuacion = localArray.sum\n",
    "val visitantePuntuacion = visitanteArray.sum\n",
    "\n",
    "println(s\"Puntuación Local: ${localPuntuacion}\")\n",
    "println(s\"Puntuación Visitante: ${visitantePuntuacion}\")\n",
    "if (localPuntuacion > visitantePuntuacion) {\n",
    "    println(\"Resultado: Victoria del equipo local\")\n",
    "} else if (localPuntuacion < visitantePuntuacion) {\n",
    "    println(\"Resultado: Victoria del equipo visitante\")\n",
    "} else {\n",
    "    println(\"Resultado: Empate\")\n",
    "}\n",
    "\n",
    "val cuartos = localArray.zip(visitanteArray)\n",
    "\n",
    "println(\"\\nPuntuación por cuartos:\")\n",
    "cuartos.zipWithIndex.foreach { case ((local, visitante), index) =>\n",
    "    println(f\"  Q${index + 1}: $local - $visitante\")\n",
    "}"
   ]
