      "text/plain": [
       "\u001b[36mhistorial\u001b[39m: \u001b[32mVector\u001b[39m[\u001b[32mString\u001b[39m] = \u001b[33mVector\u001b[39m(\n",
       "  \u001b[32m\"usuario_01 login\"\u001b[39m,\n",
