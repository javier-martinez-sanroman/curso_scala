    "class CuentaAhorros(val titular: String, var saldo: Double) {\n",
    "    var historialTransacciones: List[String] = List(f\"Saldo inicial: ${saldo}%.2f €\")\n",
    "\n",
    "    def ingresar(cantidad: Double): Unit = {\n",
    "        if (cantidad > 0) {\n",
    "            saldo += cantidad\n",
    "            historialTransacciones = historialTransacciones :+ f\"Depositados ${cantidad}%.2f €. Nuevo saldo: ${saldo}%.2f €\"    \n",
    "        } else {\n",
    "            println(\"Error: La cantidad a depositar debe ser positiva.\")\n",
    "        }\n",
    "    }\n",
    "\n",
    "    def retirar(cantidad: Double): Unit = {\n",
    "        if (cantidad > 0) {\n",
    "            if (cantidad <= saldo) {\n",
    "                saldo -= cantidad\n",
    "                historialTransacciones = historialTransacciones :+ f\"Retirados ${cantidad}%.2f €. Nuevo saldo: ${saldo}%.2f €\"\n",
    "            } else {\n",
    "                println(f\"Error: Fondos insuficientes para retirar: ${cantidad}%.2f €. Saldo disponible: ${saldo}%.2f €\")\n",
    "            }\n",
    "        } else {\n",
    "            println(\"Error: La cantidad a retirar debe ser positiva.\")\n",
    "        }\n",
    "    }\n",
    "\n",
    "    def obtenerSaldo(): Unit = {\n",
    "        println(f\"Titular: ${titular}, Saldo actual: ${saldo}%.2f €\")\n",
    "    }\n",
    "\n",
    "    def obtenerHistorial(): Unit = {\n",
    "        println(\"\\nHistorial de transacciones:\")\n",
    "        println(\"-\" * 30)\n",
    "        historialTransacciones.foreach(println)\n",
    "        println(\"\\n\")\n",
    "    }\n",
    "}\n",
    "\n",
    "val cuenta = new CuentaAhorros(\"Laura\", 1000.0)\n",
    "cuenta.obtenerSaldo()\n",
    "cuenta.ingresar(500.0)\n",
    "cuenta.retirar(200.0)\n",
    "cuenta.obtenerSaldo()\n",
    "cuenta.retirar(1500.0)\n",
    "cuenta.obtenerSaldo()\n",
    "//cuenta.obtenerHistorial()\n",
    "\n",
    "cuenta.obtenerSaldo()\n",
    "cuenta.ingresar(15000.0)\n",
    "cuenta.retirar(12000.0)\n",
    "cuenta.obtenerSaldo()\n",
    "cuenta.retirar(10000.0)\n",
    "cuenta.obtenerSaldo()\n",
    "cuenta.obtenerHistorial()"
   ]
