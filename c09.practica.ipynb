    "class Cancion(val titulo: String, val artista: String, val duracionSegundos: Int) {\n",
    "    def duracionFormateada(): String = {\n",
    "        val min = duracionSegundos / 60\n",
    "        val seg = duracionSegundos % 60\n",
    "        f\"${min}%02d:${seg}%02d\"\n",
    "    }\n",
    "    def descripcion(): String = f\"'${titulo}' de ${artista} (${duracionFormateada()})\"\n",
    "}\n",
    "\n",
    "object Reproductor{\n",
    "    var volumen: Int = 50\n",
    "\n",
    "    def reproducir(cancion: Cancion): Unit = {\n",
    "        println(f\"Reproduciendo: ${cancion.descripcion()} Volumen: ${volumen}%d\")\n",
    "    }\n",
    "    def subirVolumen(incremento: Int): Unit = {\n",
    "        volumen = (volumen + incremento).min(100)\n",
    "        println(f\"Volumen subido a ${volumen}%d\")\n",
    "    }\n",
    "    def bajarVolumen(decremento: Int): Unit = {\n",
    "        volumen = (volumen - decremento).max(0)\n",
    "        println(f\"Volumen bajado a ${volumen}%d\")\n",
    "    }\n",
    "}  \n",
    "\n",
    "val cancion = List(\n",
    "    new Cancion(\"Bohemian Rhapsody\", \"Queen\", 354),\n",
    "    new Cancion(\"Imagine\", \"John Lennon\", 183),\n",
    "    new Cancion(\"Hotel California\", \"Eagles\", 391)\n",
    ")\n",
    "\n",
    "for (c <- cancion) Reproductor.reproducir(c)\n",
    "Reproductor.subirVolumen(20)\n",
    "Reproductor.subirVolumen(20)\n",
    "Reproductor.subirVolumen(20)\n",
    "Reproductor.subirVolumen(20)\n",
    "Reproductor.bajarVolumen(60)\n",
    "Reproductor.bajarVolumen(60)"
