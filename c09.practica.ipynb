    "class PlazaParking(val numeroPlaza: Int, var matricula: String = \"\") {\n",
    "    \n",
    "    def ocupar(matricula: String): Unit = {\n",
    "        if (this.matricula.isEmpty) {\n",
    "            this.matricula = matricula\n",
    "            println(s\"[${numeroPlaza}]:ocupada por ${matricula}.\")\n",
    "        } else {\n",
    "            println(s\"Error: La plaza ${numeroPlaza} ya está ocupada.\")\n",
    "        }\n",
    "    }\n",
    "\n",
    "    def liberar(): Unit = {\n",
    "        if (!this.matricula.isEmpty) {\n",
    "            this.matricula = \"\"\n",
    "            println(s\"[${numeroPlaza}]:liberada\")\n",
    "        } else {\n",
    "            println(s\"Error: La plaza ${numeroPlaza} ya está libre.\")\n",
    "        }\n",
    "    }\n",
    "\n",
    "    def estaLibre(): Boolean = this.matricula.isEmpty\n",
    "\n",
    "    def estado(): Unit = {\n",
    "        println(s\"[${numeroPlaza}]:${if (matricula.isEmpty) \"LIBRE\" else matricula}\")\n",
    "    }\n",
    "}\n",
    "\n",
    "\n",
    "val parking = List(\n",
    "    new PlazaParking(1),\n",
    "    new PlazaParking(2),\n",
    "    new PlazaParking(3)\n",
    ")\n",
    "\n",
    "def mostrarEstadoParking(): Unit = {\n",
    "    println(\"\\n*** Estado del parking ***\")\n",
    "    println(\"=\" * 30)\n",
    "    parking.foreach(_.estado())\n",
    "    \n",
    "}\n",
    "\n",
    "mostrarEstadoParking()\n",
    "\n",
    "parking(0).ocupar(\"1234 ABC\")\n",
    "parking(1).ocupar(\"5678 DEF\")\n",
    "mostrarEstadoParking()\n",
    "\n",
    "parking(0).liberar()\n",
    "parking(2).liberar()\n",
    "mostrarEstadoParking()\n",
    "\n"
   ]
